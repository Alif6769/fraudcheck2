// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Order {
  id              Int      @id @default(autoincrement())
  orderId         String
  orderName       String   @unique
  shop            String
  orderTime       DateTime
  updatedAt       DateTime?
  cancelledAt     DateTime?
  fulfilledAt     DateTime? // when the order was marked fulfilled
  fulfillmentStatus String? // e.g., "fulfilled", "partial", "unfulfilled"
  customerId      String?
  firstName       String?
  lastName        String?
  contactPhone    String?
  shippingPhone   String?
  shippingAddress String?
  totalPrice      String
  shippingFee     String
  products        Json
  // new fields
  productIds        Json?
  source          String? // e.g., "web", "pos", etc.
  fraudReport     String? // full text report from FraudSpy
  steadFastReport String?
  realName1       String?
  realName2       String?
}

model UnfulfilledOrder {
  id              Int      @id @default(autoincrement())
  orderId         String
  orderName       String   @unique
  shop            String
  orderTime       DateTime
  updatedAt       DateTime?
  cancelledAt     DateTime?
  fulfilledAt     DateTime? // when the order was marked fulfilled
  fulfillmentStatus String? // e.g., "fulfilled", "partial", "unfulfilled"
  customerId      String?
  firstName       String?
  lastName        String?
  contactPhone    String?
  shippingPhone   String?
  shippingAddress String?
  totalPrice      String
  shippingFee     String
  products        Json
  // new fields
  productIds        Json?
  source          String? // e.g., "web", "pos", etc.
}

model CancelledOrder {
  id              Int      @id @default(autoincrement())
  orderId         String
  orderName       String   @unique
  shop            String
  orderTime       DateTime
  updatedAt       DateTime?
  cancelledAt     DateTime
  fromDateTime    DateTime
  toDateTime      DateTime
  customerId      String?
  firstName       String?
  lastName        String?
  contactPhone    String?
  shippingPhone   String?
  shippingAddress String?
  totalPrice      String
  shippingFee     String
  products        Json
  // new fields
  productIds        Json?
  source          String? // e.g., "web", "pos", etc.
}

// Product table
model DailyInventorySnapshot {
  id               String               @id @default(cuid())
  productId        String               @unique
  productName      String
  price            Float?
  quantity         Int                  @default(0)  // current stock
  shop            String
  description      String?
  inventoryCategory String?
  productCategory   String?
  isCombo          Boolean              @default(false)
  rawProductFlag   Boolean              @default(false)
  isDuplicate      Boolean  @default(false)
  rootProductId    String?                        // for duplicate products
  comboReference   Json?                          // for combo products
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  todayDateTime    DateTime?
  fulfilledSales   Int      @default(0) // total fulfilled sales from that day's transactions (SALE)
  fulfilledManual  Int      @default(0) // MANUAL_SALE
  fulfilledReturn  Int      @default(0) // RETURN
  fulfilledDamage  Int      @default(0) // DAMAGE
  unfulfilledSales   Int      @default(0) // total fulfilled sales from that day's transactions (SALE)
  unfulfilledManual  Int      @default(0) // MANUAL_SALE
  unfulfilledReturn  Int      @default(0) // RETURN
  unfulfilledDamage  Int      @default(0) // DAMAGE
  cancelledSales   Int      @default(0) // total fulfilled sales from that day's transactions (SALE)
  cancelledManual  Int      @default(0) // MANUAL_SALE
  cancelledReturn  Int      @default(0) // RETURN
  cancelledDamage  Int      @default(0) // DAMAGE
}

model ProcessedOrderRange {
  id                     Int      @id @default(autoincrement())
  shop                   String   // which shop/session this belongs to

  /// Earliest processed orderTime in this shop’s history
  fromDateTime           DateTime
  /// Latest processed orderTime in this shop’s history
  toDateTime             DateTime

  /// Optional stats for this particular run
  processedOrdersCount   Int
  processedOrderNameFrom String?
  processedOrderNameTo   String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ShopSettings {
  shop             String   @id // e.g. "myshop.myshopify.com"
  fetchLimit       Int      @default(100)
  reportLimit      Int      @default(10)
  fraudspyEnabled  Boolean  @default(false)
  steadfastEnabled Boolean  @default(true)
  telegramEnabled  Boolean  @default(true)
  allSources       Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

// Product table
model Product {
  id               String               @id @default(cuid())
  productId        String               @unique
  productName      String
  price            Float?
  quantity         Int                  @default(0)  // current stock
  description      String?
  inventoryCategory String?
  productCategory   String?
  isCombo          Boolean              @default(false)
  rawProductFlag   Boolean              @default(false)
  isDuplicate      Boolean  @default(false)
  rootProductId    String?                        // for duplicate products
  comboReference   Json?                          // for combo products
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  baseDatetime     DateTime?
  shop             String?
  // Relation to all transactions
  transactions     ProductTransaction[]

  // Optional: daily inventory summaries
  InventoryDaily   InventoryDaily[]
}

// Enum for transaction types
enum TransactionType {
  SALE
  RETURN
  DAMAGE
  MANUAL_SALE
}

// Transaction table
model ProductTransaction {
  id        String          @id @default(cuid())
  productId String
  type      TransactionType
  quantity  Int
  timestamp DateTime        @default(now())

  product   Product         @relation(fields: [productId], references: [productId], onDelete: Cascade)
}

// Daily summary table
model InventoryDaily {
  id               String   @id @default(cuid())
  productId        String
  date             DateTime  // only store date, ignore time
  sold             Int       @default(0)
  returned         Int       @default(0)
  damaged          Int       @default(0)
  closingInventory Int
  product          Product   @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@unique([productId, date])
}

model CourierService {
  id                 BigInt   @id @default(autoincrement())
  name               String   @unique // 'pathao', 'steadfast'
  displayName        String   @map("display_name")
  trackingUrlPattern String?  @map("tracking_url_pattern")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  credentials ShopCourierCredentials[]

  @@map("courier_services")
}

model ShopCourierCredentials {
  id                BigInt   @id @default(autoincrement())
  shopDomain        String   @map("shop_domain")                 // just a string, no relation
  courierServiceId  BigInt   @map("courier_service_id")
  credentials       String                                       // encrypted JSON
  accessToken       String?  @map("access_token")                // encrypted (for Pathao)
  refreshToken      String?  @map("refresh_token")               // encrypted (for Pathao)
  tokenExpiresAt    DateTime? @map("token_expires_at")
  storeId           String?  @map("store_id")                    // courier-specific store ID
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Keep relation to CourierService (that's fine)
  courierService    CourierService @relation(fields: [courierServiceId], references: [id], onDelete: Cascade)

  @@unique([shopDomain, courierServiceId])
  @@map("shop_courier_credentials")
}

model ProcessedFulfillment {
  orderId     String   @id
  processedAt DateTime @default(now())
}

