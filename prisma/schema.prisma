// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean  @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Order {
  id              Int      @id @default(autoincrement())
  orderId         String   
  orderName       String   @unique
  shop            String
  orderTime       DateTime
  customerId      String?
  firstName       String?
  lastName        String?
  contactPhone    String?
  shippingPhone   String?
  shippingAddress String?
  totalPrice      String
  shippingFee     String
  products        Json
  // new fields
  source          String?   // e.g., "web", "pos", etc.
  fraudReport     String?   // full text report from FraudSpy
  steadFastReport String?
  realName1       String?
  realName2       String?
}

model ShopSettings {
  shop             String @id   // e.g. "myshop.myshopify.com"
  fetchLimit       Int    @default(100)
  reportLimit      Int    @default(10)
  fraudspyEnabled  Boolean @default(false)
  steadfastEnabled Boolean @default(true)
  telegramEnabled  Boolean @default(true)
  allSources       Boolean @default(false)
  updatedAt        DateTime @updatedAt
}

model Product {
  id                     String   @id @default(cuid())
  productId              String   @unique
  productName            String
  price                  Float?
  inventoryCategory      String?
  productCategory        String?
  shortForm              String?
  isCombo                Boolean  @default(false)
  rawProductFlag         Boolean  @default(false)
  isDuplicate            Boolean  @default(false)
  rootProductId          String?  // ID of the root product if this is a duplicate
  comboReference         String?  // JSON array of { productId, quantity }
  inventoryWarningLevel  Int?
  baseDatetime           DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  inventoryDaily         InventoryDaily[]
}
